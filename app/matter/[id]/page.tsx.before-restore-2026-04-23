"use client";

import { use, useEffect, useMemo, useState } from "react";

type MatterRow = {
  matterId?: number;
  id?: number;
  displayNumber?: string;
  description?: string;
  claimNumber?: string;
  claimAmount?: number | string;
  masterLawsuitId?: string | null;
  lawsuitMatters?: string | null;
  locked?: boolean;
};

type MatterContext = {
  id?: number;
  display_number?: string;
  description?: string;
};

function getMatterId(row: MatterRow): number {
  return Number(row.matterId ?? row.id ?? 0);
}

function getGroupKey(row: MatterRow): string | null {
  const key = row.masterLawsuitId;
  return key && String(key).trim() !== "" ? String(key) : null;
}

function isGrouped(row: MatterRow): boolean {
  return !!getGroupKey(row);
}

function formatMoney(value: number | string | undefined): string {
  const n = Number(value ?? 0);
  return new Intl.NumberFormat("en-US", {
    style: "currency",
    currency: "USD",
  }).format(Number.isFinite(n) ? n : 0);
}

function hashString(input: string): number {
  let h = 0;
  for (let i = 0; i < input.length; i++) {
    h = (h << 5) - h + input.charCodeAt(i);
    h |= 0;
  }
  return Math.abs(h);
}

function getGroupedRowColor(groupKey: string): string {
  const palette = [
    "#f3f7ff",
    "#f1fbf5",
    "#fff8ef",
    "#f8f3ff",
    "#fff3f3",
    "#f2fbfb",
  ];
  return palette[hashString(groupKey) % palette.length];
}

function getBandColor(groupKey: string | null): string {
  if (!groupKey) return "#f3f4f6";

  const palette = [
    "#dbe7ff",
    "#dff4e5",
    "#fff0cc",
    "#eadcff",
    "#ffe0e0",
    "#dff4f4",
  ];
  return palette[hashString(groupKey) % palette.length];
}

export default function MatterPage({
  params,
}: {
  params: Promise<{ id: string }>;
}) {
  const { id } = use(params);

  const [matter, setMatter] = useState<MatterContext | null>(null);
  const [siblings, setSiblings] = useState<MatterRow[]>([]);
  const [selectedIds, setSelectedIds] = useState<number[]>([]);
  const [loading, setLoading] = useState(true);
  const [busy, setBusy] = useState(false);
  const [error, setError] = useState("");

  async function loadPage() {
    setLoading(true);
    setError("");

    try {
      const [matterRes, siblingsRes] = await Promise.all([
        fetch(`/api/clio/matter-context?matterId=${id}`, {
          cache: "no-store",
        }),
        fetch(`/api/aggregation/find-siblings?matterId=${id}`, {
          cache: "no-store",
        }),
      ]);

      const matterJson = await matterRes.json();
      const siblingsJson = await siblingsRes.json();

      if (matterJson?.ok) {
        setMatter(matterJson.matter ?? null);
      } else {
        setMatter(null);
      }

      if (siblingsJson?.ok && Array.isArray(siblingsJson.siblings)) {
        setSiblings(siblingsJson.siblings);
      } else {
        setSiblings([]);
      }
    } catch (err: any) {
      setError(err?.message || "Failed to load matter page.");
      setMatter(null);
      setSiblings([]);
    } finally {
      setLoading(false);
    }
  }

  useEffect(() => {
    loadPage();
  }, [id]);

  const selectedRows = useMemo(() => {
    return siblings.filter((row) => selectedIds.includes(getMatterId(row)));
  }, [siblings, selectedIds]);

  const selectedExistingGroupKeys = useMemo(() => {
    return Array.from(
      new Set(
        selectedRows
          .map((row) => getGroupKey(row))
          .filter((v): v is string => Boolean(v))
      )
    );
  }, [selectedRows]);

  const activeExistingGroupKey =
    selectedExistingGroupKeys.length === 1
      ? selectedExistingGroupKeys[0]
      : null;

  const hasMixedExistingGroups = selectedExistingGroupKeys.length > 1;

  function rowIsDisabled(row: MatterRow): boolean {
    const rowId = getMatterId(row);

    if (selectedIds.includes(rowId)) return false;
    if (!activeExistingGroupKey) return false;

    const rowGroupKey = getGroupKey(row);
    return Boolean(rowGroupKey && rowGroupKey !== activeExistingGroupKey);
  }

  function rowDisableReason(row: MatterRow): string {
    const rowGroupKey = getGroupKey(row);

    if (!activeExistingGroupKey) return "";
    if (!rowGroupKey) return "";
    if (rowGroupKey === activeExistingGroupKey) return "";

    return `Unavailable because selection is constrained to lawsuit ${activeExistingGroupKey}.`;
  }

  const canAggregate =
    selectedIds.length >= 2 &&
    !hasMixedExistingGroups &&
    !busy;

  async function handleAggregate() {
    if (!canAggregate) return;

    setBusy(true);
    setError("");

    try {
      const res = await fetch("/api/aggregate", {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
        },
        body: JSON.stringify({
          matterIds: selectedIds,
        }),
      });

      const json = await res.json();

      if (!res.ok || !json?.ok) {
        throw new Error(json?.error || "Aggregation failed.");
      }

      setSelectedIds([]);
      await loadPage();
    } catch (err: any) {
      setError(err?.message || "Aggregation failed.");
    } finally {
      setBusy(false);
    }
  }

  async function handleDeaggregateActiveGroup() {
    if (!activeExistingGroupKey) return;

    const idsInGroup = siblings
      .filter((row) => getGroupKey(row) === activeExistingGroupKey)
      .map((row) => getMatterId(row));

    if (idsInGroup.length === 0) return;

    const ok = window.confirm(
      `De-aggregate lawsuit ${activeExistingGroupKey}? This will clear MASTER_LAWSUIT_ID and LAWSUIT_MATTERS on the grouped matters.`
    );

    if (!ok) return;

    setBusy(true);
    setError("");

    try {
      const res = await fetch("/api/deaggregate", {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
        },
        body: JSON.stringify({
          matterIds: idsInGroup,
          masterLawsuitId: activeExistingGroupKey,
        }),
      });

      const json = await res.json();

      if (!res.ok || !json?.ok) {
        throw new Error(json?.error || "De-aggregation failed.");
      }

      setSelectedIds([]);
      await loadPage();
    } catch (err: any) {
      setError(err?.message || "De-aggregation failed.");
    } finally {
      setBusy(false);
    }
  }

  function toggleRow(row: MatterRow) {
    const rowId = getMatterId(row);

    if (!rowId) return;
    if (rowIsDisabled(row)) return;

    setSelectedIds((current) =>
      current.includes(rowId)
        ? current.filter((id) => id !== rowId)
        : [...current, rowId]
    );
  }

  const rowsForDisplay = useMemo(() => {
    const grouped: MatterRow[] = [];
    const ungrouped: MatterRow[] = [];

    for (const row of siblings) {
      if (isGrouped(row)) grouped.push(row);
      else ungrouped.push(row);
    }

    grouped.sort((a, b) => {
      const aGroup = getGroupKey(a) || "";
      const bGroup = getGroupKey(b) || "";
      if (aGroup !== bGroup) return aGroup.localeCompare(bGroup);

      const aNum = (a.displayNumber || "").toString();
      const bNum = (b.displayNumber || "").toString();
      return aNum.localeCompare(bNum, undefined, { numeric: true });
    });

    ungrouped.sort((a, b) => {
      const aNum = (a.displayNumber || "").toString();
      const bNum = (b.displayNumber || "").toString();
      return aNum.localeCompare(bNum, undefined, { numeric: true });
    });

    return [...grouped, ...ungrouped];
  }, [siblings]);

  if (loading) {
    return (
      <main
        style={{
          padding: "32px 40px",
          fontFamily: "Arial, sans-serif",
          maxWidth: "1440px",
          margin: "0 auto",
          color: "#111827",
        }}
      >
        <div style={{ fontSize: "16px" }}>Loading matter page...</div>
      </main>
    );
  }

  return (
    <main
      style={{
        padding: "32px 40px",
        fontFamily: "Arial, sans-serif",
        maxWidth: "1440px",
        margin: "0 auto",
        color: "#111827",
      }}
    >
      <div style={{ marginBottom: "20px" }}>
        <div
          style={{
            fontSize: "32px",
            fontWeight: 700,
            letterSpacing: "-0.02em",
            marginBottom: "8px",
          }}
        >
          Lawsuit Aggregation
        </div>

        <div style={{ fontSize: "17px", marginBottom: "6px" }}>
          <strong>Source matter:</strong>{" "}
          {matter?.display_number || `Matter ${id}`}
        </div>

        {matter?.description ? (
          <div style={{ fontSize: "15px", color: "#4b5563" }}>
            {matter.description}
          </div>
        ) : null}
      </div>

      <div
        style={{
          display: "flex",
          gap: "12px",
          flexWrap: "wrap",
          marginBottom: "18px",
        }}
      >
        <button
          onClick={handleAggregate}
          disabled={!canAggregate}
          style={{
            height: "44px",
            padding: "0 18px",
            borderRadius: "10px",
            border: "1px solid #c7cdd4",
            background: canAggregate ? "#ffffff" : "#f3f4f6",
            color: "#111827",
            fontSize: "15px",
            fontWeight: 600,
            cursor: canAggregate ? "pointer" : "not-allowed",
            opacity: canAggregate ? 1 : 0.6,
          }}
        >
          {busy ? "Working..." : "Aggregate Selected"}
        </button>

        <button
          onClick={handleDeaggregateActiveGroup}
          disabled={!activeExistingGroupKey || busy}
          style={{
            height: "44px",
            padding: "0 18px",
            borderRadius: "10px",
            border: "1px solid #c7cdd4",
            background:
              activeExistingGroupKey && !busy ? "#ffffff" : "#f3f4f6",
            color: "#111827",
            fontSize: "15px",
            fontWeight: 600,
            cursor:
              activeExistingGroupKey && !busy ? "pointer" : "not-allowed",
            opacity: activeExistingGroupKey && !busy ? 1 : 0.6,
          }}
        >
          {activeExistingGroupKey
            ? `De-aggregate Selected Lawsuit (${activeExistingGroupKey})`
            : "De-aggregate Selected Lawsuit"}
        </button>

        <button
          onClick={() => setSelectedIds([])}
          disabled={selectedIds.length === 0 || busy}
          style={{
            height: "44px",
            padding: "0 18px",
            borderRadius: "10px",
            border: "1px solid #c7cdd4",
            background:
              selectedIds.length > 0 && !busy ? "#ffffff" : "#f3f4f6",
            color: "#111827",
            fontSize: "15px",
            fontWeight: 600,
            cursor:
              selectedIds.length > 0 && !busy ? "pointer" : "not-allowed",
            opacity: selectedIds.length > 0 && !busy ? 1 : 0.6,
          }}
        >
          Clear Selection
        </button>
      </div>

      <div
        style={{
          marginBottom: "18px",
          padding: "16px 18px",
          borderRadius: "12px",
          background: "#f8fafc",
          border: "1px solid #d9dee5",
          fontSize: "15px",
          lineHeight: 1.55,
        }}
      >
        <div style={{ marginBottom: "6px" }}>
          <strong>Selected matters:</strong> {selectedIds.length}
        </div>

        <div style={{ color: "#374151" }}>
          Once you select a matter from an existing lawsuit group, rows from
          other existing lawsuit groups are automatically disabled.
          Unaggregated matters remain available.
        </div>

        {activeExistingGroupKey ? (
          <div style={{ marginTop: "8px" }}>
            <strong>Active lawsuit group:</strong> {activeExistingGroupKey}
          </div>
        ) : null}
      </div>

      {hasMixedExistingGroups ? (
        <div
          style={{
            marginBottom: "18px",
            padding: "14px 16px",
            borderRadius: "12px",
            background: "#fff7ed",
            border: "1px solid #fed7aa",
            color: "#9a3412",
            fontSize: "15px",
            fontWeight: 600,
          }}
        >
          Invalid selection: matters from different existing lawsuit groups
          cannot be combined.
        </div>
      ) : null}

      {error ? (
        <div
          style={{
            marginBottom: "18px",
            padding: "14px 16px",
            borderRadius: "12px",
            background: "#fef2f2",
            border: "1px solid #fecaca",
            color: "#991b1b",
            fontSize: "15px",
            fontWeight: 600,
          }}
        >
          {error}
        </div>
      ) : null}

      <div
        style={{
          border: "1px solid #cfd5dc",
          borderRadius: "14px",
          overflow: "hidden",
          background: "#ffffff",
          boxShadow: "0 1px 2px rgba(0,0,0,0.04)",
        }}
      >
        <table
          style={{
            width: "100%",
            borderCollapse: "separate",
            borderSpacing: 0,
            tableLayout: "fixed",
          }}
        >
          <thead>
            <tr style={{ background: "#111111", color: "#ffffff" }}>
              <th
                style={{
                  width: "70px",
                  textAlign: "left",
                  padding: "14px 14px",
                  fontSize: "15px",
                  fontWeight: 700,
                }}
              >
                Pick
              </th>
              <th
                style={{
                  width: "160px",
                  textAlign: "left",
                  padding: "14px 14px",
                  fontSize: "15px",
                  fontWeight: 700,
                }}
              >
                Matter
              </th>
              <th
                style={{
                  textAlign: "left",
                  padding: "14px 14px",
                  fontSize: "15px",
                  fontWeight: 700,
                }}
              >
                Description
              </th>
              <th
                style={{
                  width: "140px",
                  textAlign: "left",
                  padding: "14px 14px",
                  fontSize: "15px",
                  fontWeight: 700,
                }}
              >
                Claim #
              </th>
              <th
                style={{
                  width: "170px",
                  textAlign: "right",
                  padding: "14px 14px",
                  fontSize: "15px",
                  fontWeight: 700,
                }}
              >
                Claim Amount
              </th>
              <th
                style={{
                  width: "190px",
                  textAlign: "left",
                  padding: "14px 14px",
                  fontSize: "15px",
                  fontWeight: 700,
                }}
              >
                Status
              </th>
            </tr>
          </thead>

          <tbody>
            {rowsForDisplay.map((row, index) => {
              const rowId = getMatterId(row);
              const checked = selectedIds.includes(rowId);
              const disabled = rowIsDisabled(row);
              const groupKey = getGroupKey(row);

              const prevRow = index > 0 ? rowsForDisplay[index - 1] : null;
              const prevGroupKey = prevRow ? getGroupKey(prevRow) : null;
              const showBand = index === 0 || prevGroupKey !== groupKey;

              const activeGroupMatch =
                !!groupKey &&
                !!activeExistingGroupKey &&
                groupKey === activeExistingGroupKey;

              const baseBackground = checked
                ? "#dcfce7"
                : disabled
                ? "#f3f4f6"
                : groupKey
                ? getGroupedRowColor(groupKey)
                : "#ffffff";

              return (
                <FragmentRow key={rowId || `row-${index}`}>
                  {showBand ? (
                    <tr>
                      <td
                        colSpan={6}
                        style={{
                          padding: "11px 14px",
                          background: getBandColor(groupKey),
                          borderTop:
                            index === 0 ? "none" : "2px solid #d5dbe3",
                          borderBottom: "1px solid #d5dbe3",
                          fontWeight: 700,
                          fontSize: "14px",
                          color: "#1f2937",
                        }}
                      >
                        {groupKey
                          ? `Existing Lawsuit Group: ${groupKey}`
                          : "Unaggregated Matters"}
                        {activeGroupMatch ? "  —  ACTIVE" : ""}
                      </td>
                    </tr>
                  ) : null}

                  <tr
                    title={disabled ? rowDisableReason(row) : ""}
                    style={{
                      background: baseBackground,
                      color: disabled ? "#6b7280" : "#111827",
                      opacity: disabled ? 0.58 : 1,
                    }}
                  >
                    <td
                      style={{
                        padding: "14px 14px",
                        borderBottom: "1px solid #e5e7eb",
                        verticalAlign: "middle",
                      }}
                    >
                      <input
                        type="checkbox"
                        checked={checked}
                        disabled={disabled || busy}
                        onChange={() => toggleRow(row)}
                        style={{
                          width: "20px",
                          height: "20px",
                          cursor:
                            disabled || busy ? "not-allowed" : "pointer",
                        }}
                      />
                    </td>

                    <td
                      style={{
                        padding: "14px 14px",
                        borderBottom: "1px solid #e5e7eb",
                        verticalAlign: "middle",
                        fontSize: "16px",
                        fontWeight: 700,
                        whiteSpace: "nowrap",
                      }}
                    >
                      {row.displayNumber || `Matter ${rowId}`}
                      {groupKey ? (
                        <span
                          style={{ marginLeft: "8px", fontSize: "18px" }}
                          title="Locked aggregated matter"
                        >
                          🔒
                        </span>
                      ) : null}
                    </td>

                    <td
                      style={{
                        padding: "14px 14px",
                        borderBottom: "1px solid #e5e7eb",
                        verticalAlign: "middle",
                        fontSize: "15px",
                        color: disabled ? "#6b7280" : "#374151",
                      }}
                    >
                      {row.description || ""}
                    </td>

                    <td
                      style={{
                        padding: "14px 14px",
                        borderBottom: "1px solid #e5e7eb",
                        verticalAlign: "middle",
                        fontSize: "15px",
                      }}
                    >
                      {row.claimNumber || ""}
                    </td>

                    <td
                      style={{
                        padding: "14px 14px",
                        borderBottom: "1px solid #e5e7eb",
                        verticalAlign: "middle",
                        textAlign: "right",
                        fontSize: "16px",
                        fontVariantNumeric: "tabular-nums",
                        whiteSpace: "nowrap",
                      }}
                    >
                      {formatMoney(row.claimAmount)}
                    </td>

                    <td
                      style={{
                        padding: "14px 14px",
                        borderBottom: "1px solid #e5e7eb",
                        verticalAlign: "middle",
                        fontSize: "14px",
                        lineHeight: 1.4,
                      }}
                    >
                      {disabled
                        ? rowDisableReason(row)
                        : groupKey
                        ? `Grouped in lawsuit ${groupKey}`
                        : "Available"}
                    </td>
                  </tr>
                </FragmentRow>
              );
            })}
          </tbody>
        </table>
      </div>
    </main>
  );
}

function FragmentRow({ children }: { children: React.ReactNode }) {
  return <>{children}</>;
}
