import { clioFetch } from "@/lib/clioAuth";
import { MATTER_CF } from "@/lib/clioFields";

type ClioCustomFieldValue = {
  id?: number | string;
  value?: string | number | null;
  custom_field?: {
    id?: number;
    name?: string;
  };
};

type ClioMatter = {
  id: number;
  etag?: string;
  display_number?: string;
  custom_field_values?: ClioCustomFieldValue[];
};

async function readMatter(matterId: number): Promise<ClioMatter> {
  const res = await clioFetch(`/api/v4/matters/${matterId}.json`);

  const text = await res.text();

  if (!res.ok) {
    throw new Error(`Failed to read matter ${matterId}: ${text}`);
  }

  const json = text ? JSON.parse(text) : null;
  const matter = json?.data;

  if (!matter?.id) {
    throw new Error(`Matter ${matterId} was not returned by Clio.`);
  }

  return matter as ClioMatter;
}

function findField(
  matter: ClioMatter,
  fieldId: number
): ClioCustomFieldValue | undefined {
  return matter.custom_field_values?.find(
    (cfv) => Number(cfv?.custom_field?.id) === Number(fieldId)
  );
}

export async function preflightLawsuitMatter(matterId: number) {
  const matter = await readMatter(matterId);

  const existingMaster = findField(matter, MATTER_CF.MASTER_LAWSUIT_ID);
  const existingLawsuitMatters = findField(matter, MATTER_CF.LAWSUIT_MATTERS);

  return {
    matter,
    existingMasterValue:
      existingMaster?.value == null ? "" : String(existingMaster.value).trim(),
    existingMasterFieldId: existingMaster?.id,
    existingLawsuitMattersFieldId: existingLawsuitMatters?.id,
  };
}

/**
 * CORE FIX: true upsert per custom field
 */
async function upsertCustomField({
  matterId,
  fieldId,
  value,
  existingId,
}: {
  matterId: number;
  fieldId: number;
  value: string;
  existingId?: number | string;
}) {
  // UPDATE existing
  if (existingId) {
    const res = await clioFetch(`/api/v4/custom_field_values/${existingId}`, {
      method: "PATCH",
      headers: {
        "Content-Type": "application/json",
      },
      body: JSON.stringify({
        data: { value },
      }),
    });

    const text = await res.text();

    if (!res.ok) {
      throw new Error(`PATCH failed (field ${fieldId}): ${text}`);
    }

    return;
  }

  // CREATE new
  const res = await clioFetch(`/api/v4/custom_field_values`, {
    method: "POST",
    headers: {
      "Content-Type": "application/json",
    },
    body: JSON.stringify({
      data: {
        parent: {
          id: matterId,
          type: "Matter",
        },
        custom_field: {
          id: fieldId,
        },
        value,
      },
    }),
  });

  const text = await res.text();

  if (!res.ok) {
    throw new Error(`POST failed (field ${fieldId}): ${text}`);
  }
}

export async function writeLawsuitFields(
  matterId: number,
  masterId: string,
  lawsuitMatters: string
) {
  const preflight = await preflightLawsuitMatter(matterId);

  const {
    matter,
    existingMasterValue,
    existingMasterFieldId,
    existingLawsuitMattersFieldId,
  } = preflight;

  // HARD BLOCK (correct behavior)
  if (existingMasterValue) {
    throw new Error(
      `Matter ${matter.display_number || matterId} already has MASTER LAWSUIT ID ${existingMasterValue}`
    );
  }

  // ✅ FIX: write fields individually (no bulk PATCH)
  await upsertCustomField({
    matterId,
    fieldId: MATTER_CF.MASTER_LAWSUIT_ID,
    value: masterId,
    existingId: existingMasterFieldId,
  });

  await upsertCustomField({
    matterId,
    fieldId: MATTER_CF.LAWSUIT_MATTERS,
    value: lawsuitMatters,
    existingId: existingLawsuitMattersFieldId,
  });

  return {
    matterId,
    displayNumber: matter.display_number || String(matterId),
    ok: true,
  };
}
