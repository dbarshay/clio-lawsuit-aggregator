generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model LawsuitSequenceCounter {
  id           Int      @id @default(autoincrement())
  year         Int
  month        Int
  lastSequence Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([year, month], name: "year_month")
}

model Lawsuit {
  id               Int      @id @default(autoincrement())
  masterLawsuitId  String   @unique
  claimNumber      String?
  lawsuitMatters   String
  sharedFolderPath String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model ClioToken {
  id           Int      @id @default(1)
  accessToken  String
  refreshToken String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model ClaimIndex {
  matter_id              Int     @id
  display_number         String?
  description            String?

  claim_number_raw       String?
  claim_number_normalized String?

  patient_name           String?
  client_name            String?
  insurer_name           String?

  claim_amount           Float?
  settled_amount         Float?
  payment_amount         Float?
  balance_amount         Float?

  bill_number            String?
  dos_start              String?
  dos_end                String?
  denial_reason          String?
  payment_voluntary      Float?
  balance_presuit        Float?
  master_lawsuit_id      String?

  status                 String?
  raw_json               String?
  indexed_at             DateTime @default(now())

  @@index([claim_number_normalized])
}
