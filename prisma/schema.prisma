generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model LawsuitSequenceCounter {
  id           Int      @id @default(autoincrement())
  year         Int
  month        Int
  lastSequence Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([year, month], name: "year_month")
}

model Lawsuit {
  id                          Int       @id @default(autoincrement())
  masterLawsuitId             String    @unique
  claimNumber                 String?
  lawsuitMatters              String
  sharedFolderPath            String
  venue                       String?
  venueSelection              String?
  venueOther                  String?
  indexAaaNumber              String?
  lawsuitNotes                String?
  lawsuitOptions              Json?
  amountSoughtMode            String    @default("balance_presuit")
  amountSought                Float?
  customAmountSought          Float?
  amountSoughtBreakdown       Json?
  clioMasterMatterId          Int?
  clioMasterDisplayNumber     String?
  clioMasterMatterDescription String?
  clioMasterMappedAt          DateTime?
  clioMasterMappingSource     String?
  createdAt                   DateTime  @default(now())
  updatedAt                   DateTime  @updatedAt

  @@index([clioMasterMatterId])
  @@index([clioMasterDisplayNumber])
}

model ClioToken {
  id           Int       @id @default(1)
  accessToken  String
  refreshToken String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  tokenType    String    @default("bearer")
  expiresAt    DateTime?
}

model ClaimIndex {
  matter_id               Int     @id
  display_number          String?
  description             String?
  claim_number_raw        String?
  claim_number_normalized String?
  patient_name            String?
  client_name             String?
  insurer_name            String?
  claim_amount            Float?
  settled_amount          Float?

  settled_with           String?
  allocated_settlement   Float?
  interest_amount        Float?
  principal_fee          Float?
  interest_fee           Float?
  total_fee              Float?
  provider_net           Float?
  provider_principal_net Float?
  provider_interest_net  Float?
  overdue_days           Float?
  payment_amount         Float?
  balance_amount         Float?
  bill_number            String?
  dos_start              String?
  dos_end                String?
  denial_reason          String?
  service_type           String?
  policy_number          String?
  date_of_loss           String?
  payment_voluntary      Float?
  balance_presuit        Float?
  master_lawsuit_id      String?
  status                 String?
  close_reason           String?
  final_status           String?
  raw_json               String?
  indexed_at             DateTime @default(now())
  matter_stage_name      String?
  index_aaa_number       String?
  patient_insurer        String?
  patient_provider       String?
  provider_name          String?
  treating_provider      String?

  @@index([claim_number_normalized])
  @@index([patient_name])
  @@index([provider_name])
  @@index([insurer_name])
  @@index([patient_provider])
  @@index([patient_insurer])
  @@index([master_lawsuit_id])
  @@index([index_aaa_number])
  @@index([close_reason])
  @@index([final_status])
  @@index([matter_stage_name])
  @@index([status])
  @@index([denial_reason])
  @@index([service_type])
  @@index([treating_provider])
}

model ClaimClusterCache {
  claim_number_normalized String   @id
  matter_ids              String
  updated_at              DateTime @updatedAt

  @@index([updated_at])
}

model DocumentFinalization {
  id                    Int      @id @default(autoincrement())
  masterLawsuitId       String
  masterMatterId        Int
  masterDisplayNumber   String?
  status                String
  requestedKeys         Json?
  uploaded              Json?
  skipped               Json?
  clioUploadTarget      Json?
  validationSnapshot    Json?
  packetSummarySnapshot Json?
  allowDuplicateUploads Boolean  @default(false)
  noUploadPerformed     Boolean  @default(false)
  error                 String?
  finalizedAt           DateTime @default(now())
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([masterLawsuitId])
  @@index([masterMatterId])
  @@index([status])
  @@index([finalizedAt])
}

model DocumentPrintQueueItem {
  id                         Int       @id @default(autoincrement())
  uniqueQueueKey             String    @unique
  masterLawsuitId            String
  masterMatterId             Int
  masterDisplayNumber        String?
  finalizationId             Int?
  documentKey                String
  documentLabel              String?
  filename                   String
  clioDocumentId             String?
  clioDocumentName           String?
  clioDocumentVersionUuid    String?
  status                     String    @default("queued")
  documentSnapshot           Json?
  sourceFinalizationSnapshot Json?
  queuedAt                   DateTime  @default(now())
  printedAt                  DateTime?
  printDecision              String?
  notes                      String?
  createdAt                  DateTime  @default(now())
  updatedAt                  DateTime  @updatedAt

  @@index([masterLawsuitId])
  @@index([masterMatterId])
  @@index([status])
  @@index([queuedAt])
  @@index([clioDocumentId])
}

model SettlementWriteback {
  id                Int      @id @default(autoincrement())
  masterLawsuitId   String
  status            String
  grossSettlement   Float?
  settledWith       String?
  settlementDate    String?
  allocationMode    String?
  childMatterIds    Json?
  previewSnapshot   Json?
  readinessSnapshot Json?
  writeResults      Json?
  safetySnapshot    Json?
  error             String?
  noWritePerformed  Boolean  @default(false)
  finalizedAt       DateTime @default(now())
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([masterLawsuitId])
  @@index([status])
  @@index([finalizedAt])
}

model LocalSettlementRecord {
  id                          String    @id @default(cuid())
  masterLawsuitId             String
  status                      String    @default("recorded")
  source                      String    @default("barsh-matters-local")
  payloadKind                 String?
  recordIntent                String?
  settledWith                 String?
  settlementDate              String?
  paymentExpectedDate         String?
  notes                       String?
  allocationMode              String?
  grossSettlementAmount       Float?
  interestAmountTotal         Float?
  principalFeePercent         Float?
  interestFeePercent          Float?
  allocatedSettlementTotal    Float?
  principalFeeTotal           Float?
  interestFeeTotal            Float?
  totalFee                    Float?
  providerPrincipalNetTotal   Float?
  providerInterestNetTotal    Float?
  providerNetTotal            Float?
  rowCount                    Int       @default(0)
  previewSnapshot             Json?
  roundingAdjustmentsSnapshot Json?
  safetySnapshot              Json?
  recordedBy                  String?
  recordedAt                  DateTime  @default(now())
  voided                      Boolean   @default(false)
  voidedAt                    DateTime?
  voidedBy                    String?
  voidReason                  String?
  voidSnapshot                Json?
  createdAt                   DateTime  @default(now())
  updatedAt                   DateTime  @updatedAt

  rows LocalSettlementRow[]

  @@index([masterLawsuitId])
  @@index([status])
  @@index([settlementDate])
  @@index([recordedAt])
  @@index([voided])
}

model LocalSettlementRow {
  id                   String                @id @default(cuid())
  settlementRecordId   String
  settlementRecord     LocalSettlementRecord @relation(fields: [settlementRecordId], references: [id], onDelete: Cascade)
  masterLawsuitId      String
  matterId             Int
  displayNumber        String?
  provider             String?
  patient              String?
  insurer              String?
  claimNumber          String?
  billNumber           String?
  dosStart             String?
  dosEnd               String?
  denialReason         String?
  claimAmount          Float?
  principalBasis       Float?
  allocatedSettlement  Float?
  interestAmount       Float?
  principalFee         Float?
  interestFee          Float?
  totalFee             Float?
  providerPrincipalNet Float?
  providerInterestNet  Float?
  providerNet          Float?
  settlementStatus     String?
  rowSnapshot          Json?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt

  @@index([settlementRecordId])
  @@index([masterLawsuitId])
  @@index([matterId])
  @@index([displayNumber])
  @@index([settlementStatus])
}

model MatterPaymentReceipt {
  id                     Int       @id @default(autoincrement())
  matterId               Int
  displayNumber          String?
  paymentDate            String
  paymentAmount          Float
  transactionType        String?
  transactionStatus      String?
  transactionDate        String?
  checkNumber            String?
  checkDate              String?
  invoiceId              String?
  description            String?
  transactionFee         Float?
  postedBy               String?
  posted                 Boolean   @default(true)
  voided                 Boolean   @default(false)
  voidedAt               DateTime?
  voidedBy               String?
  voidReason             String?
  reversalSnapshot       Json?
  editedAt               DateTime?
  editedBy               String?
  editReason             String?
  editSnapshot           Json?
  claimAmountBefore      Float?
  paymentVoluntaryBefore Float?
  balancePresuitBefore   Float?
  paymentVoluntaryAfter  Float?
  balancePresuitAfter    Float?
  clioReadback           Json?
  safetySnapshot         Json?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  @@index([matterId])
  @@index([displayNumber])
  @@index([paymentDate])
  @@index([transactionType])
  @@index([transactionStatus])
  @@index([voided])
  @@index([createdAt])
}

model ClaimIndexRebuildState {
  name             String    @id
  currentBrlNumber Int?
  lastProcessedAt  DateTime?
  status           String    @default("idle")
  lastError        String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([status])
  @@index([updatedAt])
}

model AuditLog {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  action     String
  summary    String
  entityType String
  fieldName  String?

  priorValue        Json?
  newValue          Json?
  details           Json?
  affectedMatterIds Json?

  matterId                  Int?
  matterDisplayNumber       String?
  masterMatterId            Int?
  masterMatterDisplayNumber String?
  masterLawsuitId           String?

  sourcePage String?
  workflow   String?

  actorName  String?
  actorEmail String?

  @@index([matterId])
  @@index([matterDisplayNumber])
  @@index([masterMatterId])
  @@index([masterMatterDisplayNumber])
  @@index([masterLawsuitId])
  @@index([createdAt])
  @@index([action])
}

model MatterLocalField {
  id                  String   @id @default(cuid())
  matterId            Int
  matterDisplayNumber String?
  fieldName           String
  fieldValue          String?
  fieldValueId        String?
  details             Json?
  source              String   @default("barsh-matters-local")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([matterId, fieldName])
  @@index([matterId])
  @@index([matterDisplayNumber])
  @@index([fieldName])
  @@index([fieldValue])
  @@index([fieldValueId])
  @@index([updatedAt])
}

model ReferenceEntity {
  id             String   @id @default(cuid())
  type           String
  displayName    String
  normalizedName String
  active         Boolean  @default(true)
  notes          String?
  details        Json?
  source         String   @default("barsh-matters-local")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  aliases ReferenceAlias[]
  providerClientInfo ProviderClientInfo?

  @@unique([type, normalizedName])
  @@index([type])
  @@index([active])
  @@index([displayName])
  @@index([normalizedName])
  @@index([createdAt])
}

model ProviderClientInfo {
  id                String   @id @default(cuid())
  referenceEntityId String   @unique

  displayNameSnapshot String?
  address             String?
  owner               String?
  providerGroup       String?

  retainerNFPrincipal    String?
  retainerNFInterest     String?
  retainerWCPrincipal    String?
  retainerWCInterest     String?
  retainerLiensPrincipal String?
  retainerLiensInterest  String?

  pullCosts String?
  remit     String?
  notes     String?

  source    String   @default("admin-client-info")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  referenceEntity ReferenceEntity @relation(fields: [referenceEntityId], references: [id], onDelete: Restrict)

  @@index([referenceEntityId])
  @@index([displayNameSnapshot])
  @@index([owner])
  @@index([providerGroup])
  @@index([pullCosts])
  @@index([remit])
  @@index([updatedAt])
}

model ReferenceAlias {
  id              String   @id @default(cuid())
  entityId        String
  alias           String
  normalizedAlias String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  entity ReferenceEntity @relation(fields: [entityId], references: [id], onDelete: Restrict)

  @@unique([entityId, normalizedAlias])
  @@index([entityId])
  @@index([normalizedAlias])
}

model MaildropAddress {
  id                  String    @id @default(cuid())
  source              String    @default("local_registry")
  matterId            Int?
  matterDisplayNumber String?
  masterLawsuitId     String?
  clioMatterId        Int?
  clioDisplayNumber   String?
  clioMaildropEmail   String    @unique
  clioMaildropLabel   String?
  active              Boolean   @default(true)
  lastResolvedAt      DateTime?
  metadata            Json?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([active])
  @@index([matterId])
  @@index([matterDisplayNumber])
  @@index([masterLawsuitId])
  @@index([clioMatterId])
  @@index([clioDisplayNumber])
  @@index([lastResolvedAt])
}

model EmailThread {
  id                       String         @id @default(cuid())
  provider                 String         @default("microsoft_graph")
  mailboxUserId            String?
  mailboxUserPrincipalName String?
  conversationId           String
  internetMessageId        String?
  subject                  String?
  normalizedSubject        String?
  latestMessageAt          DateTime?
  lastSyncedAt             DateTime?
  direction                String?
  source                   String?
  matterId                 Int?
  matterDisplayNumber      String?
  masterLawsuitId          String?
  clioMatterId             Int?
  clioDisplayNumber        String?
  clioMaildropEmail        String?
  clioMaildropLabel        String?
  status                   String         @default("active")
  metadata                 Json?
  createdAt                DateTime       @default(now())
  updatedAt                DateTime       @updatedAt
  messages                 EmailMessage[]

  @@unique([provider, conversationId, mailboxUserPrincipalName])
  @@index([provider])
  @@index([conversationId])
  @@index([internetMessageId])
  @@index([matterId])
  @@index([matterDisplayNumber])
  @@index([masterLawsuitId])
  @@index([clioMatterId])
  @@index([clioDisplayNumber])
  @@index([latestMessageAt])
}

model EmailMessage {
  id                       String            @id @default(cuid())
  threadId                 String
  thread                   EmailThread       @relation(fields: [threadId], references: [id], onDelete: Cascade)
  provider                 String            @default("microsoft_graph")
  mailboxUserId            String?
  mailboxUserPrincipalName String?
  graphMessageId           String?
  internetMessageId        String?
  conversationId           String?
  subject                  String?
  from                     String?
  fromEmail                String?
  toRecipients             Json?
  ccRecipients             Json?
  bccRecipients            Json?
  replyTo                  Json?
  sentAt                   DateTime?
  receivedAt               DateTime?
  folderId                 String?
  folderName               String?
  direction                String?
  isDraft                  Boolean           @default(false)
  isSent                   Boolean           @default(false)
  isRead                   Boolean?
  hasAttachments           Boolean           @default(false)
  importance               String?
  bodyPreview              String?
  bodyText                 String?
  bodyHtml                 String?
  webLink                  String?
  raw                      Json?
  createdAt                DateTime          @default(now())
  updatedAt                DateTime          @updatedAt
  attachments              EmailAttachment[]

  @@unique([provider, graphMessageId, mailboxUserPrincipalName])
  @@index([threadId])
  @@index([provider])
  @@index([graphMessageId])
  @@index([internetMessageId])
  @@index([conversationId])
  @@index([sentAt])
  @@index([receivedAt])
  @@index([folderName])
  @@index([direction])
}

model EmailAttachment {
  id                      String       @id @default(cuid())
  messageId               String
  message                 EmailMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  provider                String       @default("microsoft_graph")
  graphAttachmentId       String?
  name                    String?
  contentType             String?
  sizeBytes               Int?
  isInline                Boolean      @default(false)
  contentId               String?
  clioDocumentId          String?
  clioDocumentName        String?
  clioDocumentVersionUuid String?
  storageStatus           String       @default("metadata_only")
  metadata                Json?
  createdAt               DateTime     @default(now())
  updatedAt               DateTime     @updatedAt

  @@index([messageId])
  @@index([graphAttachmentId])
  @@index([clioDocumentId])
  @@index([storageStatus])
}

model EmailSyncState {
  id                       String    @id @default(cuid())
  provider                 String    @default("microsoft_graph")
  mailboxUserId            String?
  mailboxUserPrincipalName String?
  folderId                 String?
  folderName               String
  deltaLink                String?
  nextLink                 String?
  lastSyncedAt             DateTime?
  lastSuccessfulSyncAt     DateTime?
  lastErrorAt              DateTime?
  lastError                String?
  status                   String    @default("idle")
  metadata                 Json?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  @@unique([provider, mailboxUserPrincipalName, folderName])
  @@index([provider])
  @@index([mailboxUserPrincipalName])
  @@index([folderName])
  @@index([status])
  @@index([lastSyncedAt])
}

model EmailMatterLink {
  id                  String   @id @default(cuid())
  threadId            String?
  messageId           String?
  matterId            Int?
  matterDisplayNumber String?
  masterLawsuitId     String?
  clioMatterId        Int?
  clioDisplayNumber   String?
  linkReason          String?
  confidence          String?
  createdBy           String?
  createdAt           DateTime @default(now())
  metadata            Json?

  @@index([threadId])
  @@index([messageId])
  @@index([matterId])
  @@index([matterDisplayNumber])
  @@index([masterLawsuitId])
  @@index([clioMatterId])
  @@index([clioDisplayNumber])
}

model EmailFilingLog {
  id                 String   @id @default(cuid())
  threadId           String?
  messageId          String?
  provider           String   @default("microsoft_graph")
  targetSystem       String   @default("clio")
  targetType         String?
  targetId           String?
  action             String
  status             String   @default("preview")
  previewOnly        Boolean  @default(true)
  clioRecordsChanged Boolean  @default(false)
  databaseChanged    Boolean  @default(false)
  requestedBy        String?
  error              String?
  metadata           Json?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([threadId])
  @@index([messageId])
  @@index([targetSystem])
  @@index([targetType])
  @@index([targetId])
  @@index([action])
  @@index([status])
  @@index([createdAt])
}

model LocalWorkflowTickler {
  id                 String    @id @default(cuid())
  kind               String
  source             String    @default("barsh-matters-local")
  status             String    @default("open")
  priority           String    @default("normal")
  title              String
  description        String?
  masterLawsuitId    String?
  matterId           Int?
  displayNumber      String?
  settlementRecordId String?
  dueDate            String?
  completedAt        DateTime?
  completedBy        String?
  completedNote      String?
  metadata           Json?
  createdBy          String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([kind])
  @@index([status])
  @@index([priority])
  @@index([masterLawsuitId])
  @@index([matterId])
  @@index([displayNumber])
  @@index([settlementRecordId])
  @@index([dueDate])
  @@index([createdAt])
}

model SettlementContact {
  id        String   @id @default(cuid())
  name      String
  email     String?
  phone     String?
  company   String?
  role      String?
  notes     String?
  isActive  Boolean  @default(true)
  metadata  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([name, email])
  @@index([isActive])
}

model DocumentTemplate {
  id                    String                       @id @default(cuid())
  key                   String                       @unique
  label                 String
  category              String
  description           String?
  defaultFilenameSuffix String?
  generationEndpoint    String?
  outputFormat          String                       @default("docx")
  sourceOfTruth         String                       @default("barsh-matters-local")
  enabled               Boolean                      @default(true)
  editableInRepository  Boolean                      @default(true)
  currentVersionId      String?
  metadata              Json?
  createdAt             DateTime                     @default(now())
  updatedAt             DateTime                     @updatedAt
  versions              DocumentTemplateVersion[]
  mergeFields           DocumentTemplateMergeField[]

  @@index([category])
  @@index([enabled])
}

model DocumentTemplateVersion {
  id            String           @id @default(cuid())
  templateId    String
  versionNumber Int
  status        String           @default("draft")
  bodyFormat    String           @default("docx-template")
  storageKind   String           @default("metadata-only")
  contentText   String?
  contentJson   Json?
  mergeFieldSet String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  template      DocumentTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([templateId, versionNumber])
  @@index([templateId])
  @@index([status])
}

model DocumentTemplateMergeField {
  id           String           @id @default(cuid())
  templateId   String
  key          String
  label        String
  description  String?
  source       String
  required     Boolean          @default(false)
  exampleValue String?
  metadata     Json?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  template     DocumentTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([templateId, key])
  @@index([templateId])
  @@index([source])
}
