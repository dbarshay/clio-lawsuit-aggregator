{
  "registry": {
    "layoutAssets": [
      {
        "role": "letterhead",
        "assetKey": "brl-letterhead-main",
        "active": true,
        "requiredMergeFields": [
          "signer.email",
          "addressee.name",
          "re.line"
        ]
      },
      {
        "role": "pleadingPaper",
        "assetKey": "ny-supreme-pleading",
        "active": true,
        "requiredMergeFields": [
          "court.name",
          "caption.plaintiff",
          "caption.defendant"
        ]
      },
      {
        "role": "simpleCoverFaxPage",
        "assetKey": "standard-fax-cover",
        "active": true,
        "requiredMergeFields": [
          "fax.to",
          "fax.number"
        ]
      },
      {
        "role": "letterhead",
        "assetKey": "inactive-letterhead",
        "active": false,
        "requiredMergeFields": []
      }
    ],
    "allowedCompositions": [
      {
        "roles": [
          "letterhead"
        ]
      },
      {
        "roles": [
          "pleadingPaper"
        ]
      },
      {
        "roles": [
          "simpleCoverFaxPage"
        ]
      },
      {
        "roles": [
          "letterhead",
          "pleadingPaper"
        ]
      },
      {
        "roles": [
          "letterhead",
          "simpleCoverFaxPage"
        ]
      },
      {
        "roles": [
          "pleadingPaper",
          "simpleCoverFaxPage"
        ]
      },
      {
        "roles": [
          "letterhead",
          "pleadingPaper",
          "simpleCoverFaxPage"
        ]
      }
    ],
    "mergeFieldDefinitions": [
      {
        "key": "signer.email"
      },
      {
        "key": "addressee.name"
      },
      {
        "key": "re.line"
      },
      {
        "key": "court.name"
      },
      {
        "key": "caption.plaintiff"
      },
      {
        "key": "caption.defendant"
      },
      {
        "key": "fax.to"
      },
      {
        "key": "fax.number"
      }
    ]
  },
  "cases": [
    {
      "name": "valid three asset composition defaults deterministic order",
      "input": {
        "templateId": "tpl-valid-three",
        "templateName": "Valid Three Asset Template",
        "templateKind": "letter-pleading-fax",
        "layoutComposition": {
          "mode": "composed",
          "assets": [
            {
              "role": "letterhead",
              "assetKey": "brl-letterhead-main",
              "required": true,
              "appliesTo": "firstPage",
              "mergeFieldPolicy": "requiresTemplateFields"
            },
            {
              "role": "pleadingPaper",
              "assetKey": "ny-supreme-pleading",
              "required": true,
              "appliesTo": "bodyOnly",
              "mergeFieldPolicy": "requiresWorkflowFields"
            },
            {
              "role": "simpleCoverFaxPage",
              "assetKey": "standard-fax-cover",
              "required": true,
              "appliesTo": "coverOnly",
              "mergeFieldPolicy": "requiresWorkflowFields"
            }
          ]
        }
      },
      "expectOk": true,
      "expectWarningCodes": [
        "LAYOUT_OUTPUT_ORDER_DEFAULTED"
      ],
      "expectOutputOrder": [
        "simpleCoverFaxPage",
        "letterhead",
        "pleadingPaper"
      ]
    },
    {
      "name": "reject obsolete simple cover page alias",
      "input": {
        "templateId": "tpl-alias",
        "templateName": "Bad Alias",
        "templateKind": "fax",
        "layoutComposition": {
          "mode": "single",
          "assets": [
            {
              "role": "simpleCoverPage",
              "assetKey": "standard-fax-cover",
              "required": true,
              "appliesTo": "coverOnly",
              "mergeFieldPolicy": "requiresWorkflowFields"
            }
          ]
        }
      },
      "expectOk": false,
      "expectErrorCodes": [
        "LAYOUT_ROLE_REJECTED_ALIAS",
        "LAYOUT_ASSET_ROLE_MISMATCH"
      ]
    },
    {
      "name": "block unresolved inactive and duplicate assets",
      "input": {
        "templateId": "tpl-bad-assets",
        "templateName": "Bad Assets",
        "templateKind": "letter",
        "layoutComposition": {
          "mode": "composed",
          "assets": [
            {
              "role": "letterhead",
              "assetKey": "inactive-letterhead",
              "required": true,
              "appliesTo": "firstPage",
              "mergeFieldPolicy": "none"
            },
            {
              "role": "letterhead",
              "assetKey": "missing-letterhead",
              "required": true,
              "appliesTo": "firstPage",
              "mergeFieldPolicy": "none"
            }
          ],
          "outputOrder": [
            "letterhead"
          ]
        }
      },
      "expectOk": false,
      "expectErrorCodes": [
        "LAYOUT_ASSET_INACTIVE",
        "LAYOUT_ASSET_UNRESOLVED",
        "LAYOUT_ROLE_DUPLICATE"
      ]
    },
    {
      "name": "block missing pleading dependency",
      "input": {
        "templateId": "tpl-missing-field",
        "templateName": "Missing Field",
        "templateKind": "pleading",
        "layoutComposition": {
          "mode": "single",
          "assets": [
            {
              "role": "pleadingPaper",
              "assetKey": "ny-supreme-pleading",
              "required": true,
              "appliesTo": "bodyOnly",
              "mergeFieldPolicy": "requiresWorkflowFields",
              "requiredMergeFields": [
                "caption.indexNumber"
              ]
            }
          ],
          "outputOrder": [
            "pleadingPaper"
          ]
        }
      },
      "expectOk": false,
      "expectErrorCodes": [
        "LAYOUT_DEPENDENCY_MISSING_PLEADING_FIELD"
      ]
    }
  ]
}